Algoritmo cancun
	Definir dinero como real;
	Definir tiempo Como Entero;
	Escribir "¿Cuanto dinero tienes para el viaje?";
	Leer dinero;
	Escribir "¿Cuanto tiempo tienes para el viaje?";
	leer tiempo
	si dinero>=150000 y tiempo>=20 Entonces
